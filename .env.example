# Application settings
APP_NAME=Ws Mark Flow AI Converter
DEBUG=false
AUTH_USERNAME=admin
AUTH_PASSWORD=your-secure-password

# MongoDB connection
MONGODB_URI=mongodb://localhost:27017
MONGODB_DATABASE=ws-mark-flow-ai-converter

# LLM settings (for AI-assisted conversion)
LLM_PROVIDER=openai
LLM_API_KEY=your-openai-api-key
LLM_MODEL=gpt-4o

# PDF complexity analysis (ACCURATE strategy)
LLM_MAX_PAGES=50  # PDFs with more pages skip LLM, use Docling directly
PDF_COMPLEXITY_THRESHOLD=0.1  # 0-1 score; below this, downscale to Docling

# Batch processing
BATCH_SIZE=4  # Number of files to process concurrently

# Temp directory for file conversions
TEMP_DIR=./.data/ws-mark-flow-ai-converter

# ============ Integration Credentials (not stored in .env, passed via API) ============
# These are examples of what you'd pass in the API requests:

# SharePoint Source Config (pass in API request body):
# {
#   "type": "sharepoint",
#   "config": {
#     "client_id": "your-app-client-id",
#     "client_secret": "your-app-client-secret",
#     "tenant_id": "your-tenant-id",
#     "site_id": "your-sharepoint-site-id",
#     "drive_id": "your-drive-id",
#     "folder_id": "optional-folder-id"
#   }
# }

# Google Drive Destination Config (pass in API request body):
# {
#   "type": "google_drive",
#   "config": {
#     "service_account_json": "/path/to/service-account.json",
#     "folder_id": "optional-root-folder-id"
#   }
# }
# OR with OAuth tokens:
# {
#   "type": "google_drive", 
#   "config": {
#     "access_token": "your-access-token",
#     "refresh_token": "your-refresh-token",
#     "client_id": "your-oauth-client-id",
#     "client_secret": "your-oauth-client-secret",
#     "folder_id": "optional-root-folder-id"
#   }
# }
