    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "app:watch",
            "type": "node-terminal",
            "request": "launch",
            "command": "source .venv/bin/activate && uvicorn src.app:app --reload --host 0.0.0.0 --port 8000",
            "cwd": "${cwd}"
        },        
        {
            "name": "app:debug",
            "type": "debugpy",
            "request": "launch",
            "module": "uvicorn",
            "args": [
                "src.app:app",
                "--reload",
                "--host",
                "0.0.0.0",
                "--port",
                "8000"
            ],
            "justMyCode": false,
            "jinja": true
        }
    ]
}